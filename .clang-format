BasedOnStyle: LLVM

# --- Tabs ---
UseTab: Always
IndentWidth: 4
TabWidth: 4

# --- Compact braces (K&R style) ---
BreakBeforeBraces: Attach

# --- Keep things tight ---
AllowShortIfStatementsOnASingleLine: true
AllowShortFunctionsOnASingleLine: Inline

# --- Line width ---
ColumnLimit: 80

# --- Spacing ---
SpaceBeforeParens: ControlStatements

# --- Pointers like classic C ---
PointerAlignment: Left

# --- Includes ---
SortIncludes: true
